{
    "name": "tchubaba/tiered-throttle",
    "description": "A progressive, tier-based rate limiter for Laravel.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "tchubaba"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/cache": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/console": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0"
    },
    "autoload": {
        "psr-4": {
            "Tchubaba\\TieredThrottle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tchubaba\\TieredThrottle\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Tchubaba\\TieredThrottle\\TieredThrottleServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    }
}
